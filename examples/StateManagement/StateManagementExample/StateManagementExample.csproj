<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <!--
            In your own projects, reference the Dapr.StateManagement NuGet package instead
            of the individual project references below. The sub-packages
            (Dapr.StateManagement.Abstractions, Dapr.StateManagement.Runtime,
            Dapr.StateManagement.Generators) are not published separately to NuGet;
            only Dapr.StateManagement is.

            <PackageReference Include="Dapr.StateManagement" Version="*" />
        -->
    </PropertyGroup>

    <ItemGroup>
        <!-- Project references used only within this repository -->
        <ProjectReference Include="..\..\..\src\Dapr.StateManagement.Abstractions\Dapr.StateManagement.Abstractions.csproj" />
        <ProjectReference Include="..\..\..\src\Dapr.StateManagement.Runtime\Dapr.StateManagement.Runtime.csproj" />
        <!-- Include the source generator as an analyzer -->
        <ProjectReference Include="..\..\..\src\Dapr.StateManagement.Generators\Dapr.StateManagement.Generators.csproj"
                          ReferenceOutputAssembly="false"
                          OutputItemType="Analyzer" />
    </ItemGroup>

</Project>
