<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <PackageId>Dapr.Jobs</PackageId>
        <Title>Dapr Jobs Authoring SDK</Title>
        <Description>Dapr Jobs SDK for scheduling jobs and tasks with Dapr</Description>
        <!-- Enables the DaprVersionAwareGenerator to emit IVersionAwareDaprClient and
             VersionAwareDaprClient for this project's gRPC client. -->
        <IsDaprSdkProject>true</IsDaprSdkProject>

        <!-- Avoid creating an empty .snupkg for the analyzer child -->
        <IncludeSymbols>false</IncludeSymbols>

        <!-- Per-TFM content hook: embed the bundled Dapr.Jobs.Analyzers analyzer assembly -->
        <TargetsForTfmSpecificContentInPackage>
            $(TargetsForTfmSpecificContentInPackage);
            _AddJobsAnalyzerOnce
        </TargetsForTfmSpecificContentInPackage>
    </PropertyGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
    </ItemGroup>
    
    <ItemGroup>
        <PackageReference Include="Google.Protobuf" />
        <PackageReference Include="Grpc.Net.Client" />
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
        <PackageReference Include="Microsoft.Extensions.Http" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\Dapr.Common\Dapr.Common.csproj" />
      <ProjectReference Include="..\Dapr.Protos\Dapr.Protos.csproj" />
      <!-- Generator reference: outputs IVersionAwareDaprClient + VersionAwareDaprClient -->
      <ProjectReference Include="..\Dapr.Common.Generators\Dapr.Common.Generators.csproj"
                        OutputItemType="Analyzer"
                        ReferenceOutputAssembly="false" />

      <!-- Source-generator child project: referenced privately solely so the build system
           restores and builds it as part of this project. Its assembly is embedded into
           the package under analyzers/dotnet/cs/ via the _AddJobsAnalyzerOnce target. -->
      <ProjectReference Include="..\Dapr.Jobs.Analyzers\Dapr.Jobs.Analyzers.csproj"
                        PrivateAssets="all"
                        ReferenceOutputAssembly="false"
                        SetTargetFramework="TargetFramework=netstandard2.0" />
    </ItemGroup>

    <!-- ── Build and embed the Dapr.Jobs.Analyzers source generator under analyzers/dotnet/cs/
         (once, on the first TFM only). The Dapr.Jobs NuGet package ships as a single meta-package
         that bundles the Dapr.Jobs.Analyzers assembly rather than depending on a separate package. ── -->
    <ItemGroup>
      <_JobsGeneratorProj Include="..\Dapr.Jobs.Analyzers\Dapr.Jobs.Analyzers.csproj" />
    </ItemGroup>

    <Target Name="_AddJobsAnalyzerOnce">
      <PropertyGroup>
        <_JobsIsFirstTfm Condition="'$(TargetFramework)' == 'net8.0'">true</_JobsIsFirstTfm>
      </PropertyGroup>

      <MSBuild Condition="'$(_JobsIsFirstTfm)' == 'true'"
               Projects="@(_JobsGeneratorProj)"
               Targets="Build"
               Properties="Configuration=$(Configuration);TargetFramework=netstandard2.0" />

      <MSBuild Condition="'$(_JobsIsFirstTfm)' == 'true'"
               Projects="@(_JobsGeneratorProj)"
               Targets="GetTargetPath"
               Properties="Configuration=$(Configuration);TargetFramework=netstandard2.0">
        <Output TaskParameter="TargetOutputs" ItemName="_JobsAnalyzerOut" />
      </MSBuild>

      <ItemGroup Condition="'$(_JobsIsFirstTfm)' == 'true'">
        <TfmSpecificPackageFile Include="@(_JobsAnalyzerOut)">
          <TargetFramework>$(TargetFramework)</TargetFramework>
          <PackagePath>analyzers/dotnet/cs/%(_JobsAnalyzerOut.Filename)%(_JobsAnalyzerOut.Extension)</PackagePath>
        </TfmSpecificPackageFile>
      </ItemGroup>
    </Target>

</Project>
