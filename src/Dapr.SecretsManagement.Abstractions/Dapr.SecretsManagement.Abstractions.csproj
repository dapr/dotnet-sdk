<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <PackageId>Dapr.SecretsManagement.Abstractions</PackageId>
        <Title>Dapr Secrets Management Abstractions</Title>
        <Description>Provides abstractions for the Dapr Secrets Management SDK implementation.</Description>
