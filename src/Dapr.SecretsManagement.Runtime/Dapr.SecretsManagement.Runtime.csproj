<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <PackageId>Dapr.SecretsManagement.Runtime</PackageId>
        <Title>Dapr Secrets Management Runtime</Title>
        <Description>Provides the runtime implementation for the Dapr Secrets Management SDK.</Description>
        <!-- This assembly ships bundled inside the Dapr.SecretsManagement NuGet package; it is not published as a standalone package. -->
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Google.Protobuf" />
        <PackageReference Include="Grpc.Net.Client" />
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
        <PackageReference Include="Microsoft.Extensions.Http" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Dapr.SecretsManagement.Abstractions\Dapr.SecretsManagement.Abstractions.csproj" />
        <ProjectReference Include="..\Dapr.Common\Dapr.Common.csproj" />
        <ProjectReference Include="..\Dapr.Protos\Dapr.Protos.csproj" />
    </ItemGroup>

</Project>
