<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>Dapr.StateManagement</RootNamespace>
        <PackageId>Dapr.StateManagement.Abstractions</PackageId>
        <Title>Dapr State Management Abstractions</Title>
        <Description>Provides abstractions for the Dapr State Management SDK implementation.</Description>
        <!-- This assembly ships bundled inside the Dapr.StateManagement NuGet package; it is not published as a standalone package. -->
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Dapr.Common\Dapr.Common.csproj" />
    </ItemGroup>

</Project>
