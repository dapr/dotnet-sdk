<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Nullable>enable</Nullable>
    <PackageId>Dapr.Workflow</PackageId>
    <Title>Dapr Workflow Authoring SDK</Title>
    <Description>Dapr Workflow SDK for building workflows as code with Dapr. This package is a meta-package that pulls in the Dapr.Workflow.* family of packages.</Description>
    <VersionSuffix>alpha</VersionSuffix>
  </PropertyGroup>

  <!--
    Dapr.Workflow is a meta-package: every Dapr.Workflow.* sibling project is
    published as its own NuGet package and listed here as a NuGet dependency so
    that installing Dapr.Workflow brings in the complete authoring SDK. The
    sibling packages themselves intentionally do not depend on one another in
    their published nuspecs — the meta-package is the only place that knows
    about the full family.
  -->
  <ItemGroup>
    <ProjectReference Include="..\Dapr.Common\Dapr.Common.csproj" />
    <ProjectReference Include="..\Dapr.Workflow.Abstractions\Dapr.Workflow.Abstractions.csproj" />
    <ProjectReference Include="..\Dapr.Workflow.Grpc\Dapr.Workflow.Grpc.csproj" />
    <ProjectReference Include="..\Dapr.Workflow.Versioning.Abstractions\Dapr.Workflow.Versioning.Abstractions.csproj" />
    <ProjectReference Include="..\Dapr.Workflow.Versioning.Runtime\Dapr.Workflow.Versioning.Runtime.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" />
  </ItemGroup>

</Project>
